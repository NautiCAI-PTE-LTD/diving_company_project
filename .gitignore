# ─── Secrets / env files — NEVER commit ────────────────────────────────
**/.env
**/.env.local
!**/.env.example

# ─── Python ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
.python-version

# ─── Backend runtime artefacts ─────────────────────────────────────────
backend/storage/
backend/storage/**
*.db
*.sqlite
*.sqlite3

# ─── Model weights ─────────────────────────────────────────────────────
# The Models/ folder holds large binaries (PyTorch .pth, Keras .keras,
# species bundle .pt). They live in Google Drive instead; see
# Models/README.md for the download link. The folder itself is kept
# (Models/.gitkeep) so first-time clones get a placeholder.
Models/*
!Models/README.md
!Models/.gitkeep

# Generated artefacts from training & conversion
Models/**/*.bak
Models/**/*.train.log
Models/**/*.history.csv
Models/**/*.metrics.json
Models/**/*.onnx
Models/**/*.engine
Models/**/*.trt
Models/**/*.plan

# ─── Node / Vite ───────────────────────────────────────────────────────
node_modules/
dist/
.vite/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── IDE / OS junk ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Project-specific large folders ────────────────────────────────────
Report_to_extract_images/
"Rerun model"/
Rerun*model/
*.zip
!docs/**/*.zip

