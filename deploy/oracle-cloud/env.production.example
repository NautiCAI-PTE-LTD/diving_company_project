# Copy to repo root as .env on the Oracle Cloud VM:
#   cp deploy/oracle-cloud/env.production.example .env
#   chmod 600 .env

# ─── Host paths (persistent block volume recommended) ─────────────────
DATA_DIR=/opt/nauticai/data
API_PORT=8000

# Optional: reference PDF for BW BIRCH photo annex (leave empty to disable mount)
# REFERENCE_PDF=/opt/nauticai/data/Final_Report_BW_BIRCH.pdf

# ─── Database ───────────────────────────────────────────────────────────
# Supabase / OCI Autonomous PostgreSQL — preferred for production.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Or use bundled Postgres (docker compose --profile local-db up -d):
# POSTGRES_USER=nauticai
# POSTGRES_PASSWORD=change-me-long-random
# POSTGRES_DB=nauticai
# DATABASE_URL=postgresql://nauticai:change-me-long-random@db:5432/nauticai

# ─── Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_python_-c_import_secrets_secrets_token_urlsafe_64
JWT_ALG=HS256
JWT_EXPIRE_MIN=10080

# ─── Inference (CPU VM on OCI) ──────────────────────────────────────────
NAUTICAI_DEVICE=cpu
NAUTICAI_FP16=0
NAUTICAI_MATMUL=high
NAUTICAI_ANALYZE_CONCURRENCY=1

# ─── PDF reports ──────────────────────────────────────────────────────
NAUTICAI_REPORT_TEMPLATE=marine
# NAUTICAI_SOURCE_PDF=/app/reference/report.pdf
