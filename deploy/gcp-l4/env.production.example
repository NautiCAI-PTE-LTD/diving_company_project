# Copy to backend/.env on your GCP L4 VM (GCE with NVIDIA L4, CUDA 12.x, driver 535+)

NAUTICAI_DEVICE=cuda
NAUTICAI_GPU_PROFILE=l4

# Backend priority: TensorRT .engine > ONNX CUDA > native PyTorch
# After running deploy/gcp-l4/setup_gpu_models.sh you will have *.engine + *.onnx
NAUTICAI_BACKEND=auto

# Fast path: build Models/*.engine on this VM (setup_gpu_models.sh). Do NOT set ORT_TRT
# unless system TensorRT is installed and you skip .engine files.
# NAUTICAI_ORT_TRT=0

# L4 (24 GB VRAM): run several analyses in parallel; three ONNX models per image still serial inside one job
NAUTICAI_ANALYZE_CONCURRENCY=4

# Tensor-core friendly (Ada Lovelace L4)
NAUTICAI_FP16=1
NAUTICAI_MATMUL=high

# EasyOCR on GPU
# (OCR_GPU follows NAUTICAI_DEVICE=cuda automatically)

# Downscale huge phone photos before CNNs (faster, same 224×224 model input)
NAUTICAI_INFERENCE_MAX_EDGE=1280

# Database / auth (fill in for production)
# DATABASE_URL=postgresql://...
# JWT_SECRET=

# CORS: your S3 / CloudFront static UI origin
# NAUTICAI_CORS_ORIGINS=https://your-cloudfront-domain.cloudfront.net
