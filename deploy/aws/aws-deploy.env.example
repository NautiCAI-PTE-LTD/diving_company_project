# Copy to aws-deploy.env (gitignored) or export before deploy scripts.
# Use your GCP **static** external IP after reserving nauticai-api-ip.

GCP_API_URL=http://YOUR_GCP_STATIC_IP:8000
S3_BUCKET=nauticai-ui-prasad
AWS_REGION=ap-southeast-1

# Optional — only if you use CloudFront HTTPS for the UI
# CLOUDFRONT_DISTRIBUTION_ID=E1234567890ABC
