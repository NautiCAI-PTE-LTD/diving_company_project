# Copy this file to backend/.env and fill in real values before running.

# ─── Database ──────────────────────────────────────────────────────────
# Postgres / Supabase DSN. Leave blank to fall back to local SQLite under
# backend/storage/nauticai.db (good for laptop dev, not production).
DATABASE_URL=

# ─── Auth ──────────────────────────────────────────────────────────────
# HS256 signing secret. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_ALG=HS256
JWT_EXPIRE_MIN=10080            # 7 days

# ─── Inference knobs ───────────────────────────────────────────────────
# Force a specific compute device. Default = auto (cuda if available, else cpu).
# NAUTICAI_DEVICE=cuda

# Force a specific model backend (default = auto: trt > smart onnx > native).
# auto picks ONNX for Keras before/after on Windows (~7× faster than TF-CPU).
# NAUTICAI_BACKEND=onnx   # force all three via ONNX Runtime
# NAUTICAI_BACKEND=native # force PyTorch/Keras (dev / debugging)
# NAUTICAI_ORT_TRT=1      # ONNX Runtime TensorRT EP (if .engine not built)
# NAUTICAI_GPU_PROFILE=l4 # GCP L4 / A10 — raises analyze concurrency, ORT tuning
# NAUTICAI_ANALYZE_CONCURRENCY=4
# Photographic Report cover = image where OCR read the vessel name (default on)
# NAUTICAI_PHOTO_COVER_MATCH_OCR_NAME=1

# PDF speed (default: fast on — ~10× quicker on 500+ photo reports)
# NAUTICAI_PDF_FAST=1
# NAUTICAI_PDF_MAX_PHOTOS_PER_STAGE=9
# NAUTICAI_PDF_BIRCH_SINGLE_PASS=1
# NAUTICAI_PDF_THUMB_WORKERS=8
# Set NAUTICAI_PDF_MAX_PHOTOS_PER_STAGE=0 for every photo in the PDF (slow)
# See deploy/gcp-l4/README.md for full cloud GPU setup

# FP16 autocast on CUDA forward passes. Default on; set to 0 to force FP32.
NAUTICAI_FP16=1

# torch.set_float32_matmul_precision — leave on 'high' for Tensor cores.
NAUTICAI_MATMUL=high

# ─── PDF / reports ─────────────────────────────────────────────────────
# NAUTICAI_REPORT_TEMPLATE=marine
# NAUTICAI_SOURCE_PDF=/path/to/reference.pdf

# ─── Oracle Cloud / Docker ───────────────────────────────────────────────
# See deploy/oracle-cloud/README.md — use DATA_DIR, DATABASE_URL, JWT_SECRET in root .env for compose.
