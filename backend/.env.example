# Copy this file to backend/.env and fill in real values before running.

# ─── Database ──────────────────────────────────────────────────────────
# Postgres / Supabase DSN. Leave blank to fall back to local SQLite under
# backend/storage/nauticai.db (good for laptop dev, not production).
DATABASE_URL=

# ─── Auth ──────────────────────────────────────────────────────────────
# HS256 signing secret. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_ALG=HS256
JWT_EXPIRE_MIN=10080            # 7 days

# ─── Inference knobs ───────────────────────────────────────────────────
# Force a specific compute device. Default = auto (cuda if available, else cpu).
# NAUTICAI_DEVICE=cuda

# Force a specific model backend (default = auto: trt > onnx > native).
# Useful on Jetson if you want to A/B native PyTorch vs TensorRT.
# NAUTICAI_BACKEND=trt

# FP16 autocast on CUDA forward passes. Default on; set to 0 to force FP32.
NAUTICAI_FP16=1

# torch.set_float32_matmul_precision — leave on 'high' for Tensor cores.
NAUTICAI_MATMUL=high
