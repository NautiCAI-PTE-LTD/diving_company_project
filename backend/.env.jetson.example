# Copy to backend/.env on the Jetson edge box (no cloud DB required).
#   cp backend/.env.jetson.example backend/.env

# Leave DATABASE_URL unset — uses backend/storage/nauticai.db (SQLite).
# Do NOT paste the Supabase URL here unless the Jetson has outbound internet.

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALG=HS256
JWT_EXPIRE_MIN=10080

# GPU inference (TensorRT engines in Models/*.engine)
NAUTICAI_DEVICE=cuda
NAUTICAI_FP16=1
NAUTICAI_MATMUL=high
NAUTICAI_ANALYZE_CONCURRENCY=1
NAUTICAI_USE_SQLITE=1
