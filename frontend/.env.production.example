# Copy to frontend/.env.production before `npm run build` for AWS S3 / CloudFront.
# Use your GCP L4 API (no trailing slash).

# GCP static external IP (reserve in VPC -> IP addresses). No trailing slash.
VITE_API_URL=http://YOUR_GCP_STATIC_IP:8000
VITE_USE_MOCK=false

# Optional: require login on every fresh visit
# VITE_FORCE_LOGIN_ON_START=1
