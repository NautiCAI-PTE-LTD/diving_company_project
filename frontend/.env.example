# Set to "false" once your FastAPI/Flask backend is wired up at /api
VITE_USE_MOCK=false

# --- Supabase (frontend, OPTIONAL) -----------------------------------------
# The frontend doesn't currently call Supabase directly — auth is handled by
# the FastAPI backend. These values are read only if we add Supabase Storage
# (for logos) or Realtime in the future. SAFE to commit (publishable key
# is meant to be public).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
